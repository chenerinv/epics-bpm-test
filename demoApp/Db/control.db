### control for PID loop

record(ao, "SI:Hsetpoint")
{
    field(DESC, "Horizontal Position Setpoint")
    field(EGU, "mm")
    field(HOPR, "1")
    field(LOPR, "-1")
    field(DRVL, "-1")
    field(DRVH, "1")
    field(HIHI, "0.9")
    field(HIGH, "0.8")
    field(LOW , "-0.8")
    field(LOLO, "-0.9")
    field(PREC, "3")
    field(DOL,  "0")
    field(PINI, "YES")
}
record(ao, "SI:Vsetpoint")
{
    field(DESC, "Vertical Position Setpoint")
    field(EGU, "mm")
    field(HOPR, "1")
    field(LOPR, "-1")
    field(DRVL, "-1")
    field(DRVH, "1")
    field(HIHI, "0.9")
    field(HIGH, "0.8")
    field(LOW , "-0.8")
    field(LOLO, "-0.9")
    field(PREC, "3")
    field(DOL,  "0")
    field(PINI, "YES")
}

# Position error
# A - current position
# B - setpoint
record(calc, "SI:Herror")
{
    field(DESC, "Horizontal Position Error")
    field(SCAN, ".5 second")
    field(INPA, "SI:Xpos")
    field(INPB, "SI:Hsetpoint MS")
    field(CALC, "B-A")
    field(PREC, "3")
    field(EGU, "mm")
    field(HIGH, "0.8")
    field(HSV, "MINOR")
    field(LOW , "-0.8")
    field(LSV, "MINOR")
    field(FLNK, "SI:Hintegral")
}
record(calc, "SI:Verror")
{
    field(DESC, "Vertical Position Error")
    field(SCAN, ".5 second")
    field(INPA, "SI:Ypos")
    field(INPB, "SI:Vsetpoint MS")
    field(CALC, "B-A")
    field(PREC, "3")
    field(EGU, "mm")
    field(HIGH, "0.8")
    field(HSV, "MINOR")
    field(LOW , "-0.8")
    field(LSV, "MINOR")
    field(FLNK, "SI:Vintegral")
}

record(ao, "SI:Hintlimit")
{
  field(DESC, "Horizontal Integral Value Limit")
  field(PREC, "1")
  field(EGU, "mm*s")
  field(DOL, "2")
}
record(ao, "SI:Hgain1")
{
  field(DESC, "Horizontal Gain Kp")
  field(PREC, "1")
  field(EGU, "A/mm")
  field(DOL, "1")
}
record(ao, "SI:Hgain2")
{
  field(DESC, "Horizontal Gain Ki")
  field(PREC, "1")
  field(EGU, "A/mm-s")
  field(DOL, "4")
}

record(ao, "SI:Vintlimit")
{
  field(DESC, "Vertical Integral Value Limit")
  field(PREC, "1")
  field(EGU, "mm*s")
  field(DOL, "2")
}
record(ao, "SI:Vgain1")
{
  field(DESC, "Vertical Gain Kp")
  field(PREC, "1")
  field(EGU, "A/mm")
  field(DOL, "1")
}
record(ao, "SI:Vgain2")
{
  field(DESC, "Vertical Gain Ki")
  field(PREC, "1")
  field(EGU, "A/mm-s")
  field(DOL, "4")
}

# Integrate error (A) but assert that
# it stays within limits (C)
record(calc, "SI:Hintegral")
{
    field(DESC, "Horizontal Integrate Error for PID")
    field(EGU, "mm-s")
    field(PREC, "3")
    field(INPA, "SI:Herror PP MS")
    field(INPB, "SI:Hintegral")
    field(INPC, "SI:Hintlimit PP")
    field(INPD, "SI:Status CP")
    field(CALC, "D<1?0:(B+A>C)?C:(B+A<-C)?(-C):(B+A)")
    field(FLNK, "SI:HPID")
}
record(calc, "SI:Vintegral")
{
    field(DESC, "Vertical Integrate Error for PID")
    field(EGU, "mm-s")
    field(PREC, "3")
    field(INPA, "SI:Verror PP MS")
    field(INPB, "SI:Vintegral")
    field(INPC, "SI:Vintlimit PP")
    field(INPD, "SI:Status CP")
    field(CALC, "D<1?0:(B+A>C)?C:(B+A<-C)?(-C):(B+A)")
    field(FLNK, "SI:VPID")
}

# Every second, calculate new heater voltage via PID (PI)
# A - Kp
# B - error
# C - Ki
# D - error integral
record(calc, "SI:HPID")
{
    field(DESC, "Horizontal PID Corrector Setting")
    field(EGU, "A")
    field(PREC, "3")
    field(HIGH, "9")
    field(HSV, "MINOR")
    field(LOW , "-9")
    field(LSV, "MINOR")
    field(INPA, "SI:Hgain1 PP")
    field(INPB, "SI:Herror MS")
    field(INPC, "SI:Hgain2 PP")
    field(INPD, "SI:Hintegral MS")
    field(CALC, "A*B+C*D")
}
record(calc, "SI:VPID")
{
    field(DESC, "Vertical PID Corrector Setting")
    field(EGU, "A")
    field(PREC, "3")
    field(HIGH, "9")
    field(HSV, "MINOR")
    field(LOW , "-9")
    field(LSV, "MINOR")
    field(INPA, "SI:Vgain1 PP")
    field(INPB, "SI:Verror MS")
    field(INPC, "SI:Vgain2 PP")
    field(INPD, "SI:Vintegral MS")
    field(CALC, "A*B+C*D")
}

# patch corr to work with PID loop
record(ao, "SI:Hcorr")
{
  field(DOL, "SI:HPID CP MS")
  field(OMSL,"supervisory")
}
record(ao, "SI:Vcorr")
{
  field(DOL, "SI:VPID CP MS")
  field(OMSL,"supervisory")
}
