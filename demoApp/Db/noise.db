
record(bo, "SI:Hreset")
{
    field(DESC, "Extrema Measurement Control")   
    field(PINI, "YES")
    field(DOL,  "0")
    field(ZNAM, "Off")
    field(ONAM, "Recording")
}
record(calc, "SI:Hmax")
{  
    field(SCAN, "1 second")
    field(DESC, "Horizontal Recent Max Position")
    field(EGU, "mm")
    field(PREC, "3")
    field(INPA, "SI:Xpos PP MS")
    field(INPB, "SI:Hmax")
    field(INPC, "SI:Hreset CP")
    field(CALC, "(C<1)?(-1):(A>B)?A:(B)")
}
record(calc, "SI:Hmin")
{
    field(SCAN, "1 second")
    field(DESC, "Horizontal Recent Min Position")
    field(EGU, "mm")
    field(PREC, "3")
    field(INPA, "SI:Xpos PP MS")
    field(INPB, "SI:Hmin")
    field(INPC, "SI:Hreset CP")
    field(CALC, "(C<1)?(1):(A<B)?(A):(B)")
}
record(calc, "SI:Hnoise")
{
    field(SCAN, "1 second")
    field(DESC, "Horizontal Recent Noise")
    field(EGU, "mm")
    field(PREC, "3")
    field(INPA, "SI:Hmax PP MS")
    field(INPB, "SI:Hmin PP MS")
    field(INPC, "SI:Hreset CP")
    field(CALC, "(C<1)?(0):A-B")
}
