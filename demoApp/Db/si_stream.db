# Database for simpleInstrument.py

record(waveform, "SI:ID")
{
  field(SCAN, "1 second")
  field(FTVL, "CHAR") # field type of value
  field(NELM, "100")
  field(DTYP, "stream")
  field(INP,  "@si.proto getID SI")
}

record(bo, "SI:Control")
{
  field(SCAN, "1 second")
  field(DTYP, "stream")
  field(OUT, "@si.proto setOn SI")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

record(bi, "SI:Status")
{
  field(SCAN, ".5 second")
  field(DTYP, "stream")
  field(INP, "@si.proto getOn SI")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

# shouldn't we get the corrector readback? 
# ig it's not strictly necessary if we apply just an adjustment to the current value.

# will need to adjust Hcorr & Vcorr to do closed loop stuff later

record(ao, "SI:Hcorr")
{
  field(DESC, "H Corrector Current")
  field(DTYP, "stream")
  field(OUT, "@si.proto setHcorr SI")
  field(EGU, "A")
  field(PREC, "3")
  field(DRVL, "-10")
  field(DRVH, "10")
  field(PINI, "YES")
  field(DOL, "0")

}
record(ao, "SI:Vcorr")
{
  field(DESC, "H Corrector Current")
  field(DTYP, "stream")
  field(OUT, "@si.proto setVcorr SI")
  field(EGU, "A")
  field(PREC, "3")
  field(DRVL, "-10")
  field(DRVH, "10")
  field(PINI, "YES")
  field(DOL, "0")
}

record(ai, "SI:BPMx0")
{
  field(SCAN, ".1 second")
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmx0 SI")
  field(PREC, "2")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMx1")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmx1 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMy0")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmy0 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMy1")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmy1 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(calc, "SI:Xpos")
{
  field(INPA, "SI:BPMx0 CP MS")
  field(INPB, "SI:BPMx1 CP MS")
  field(CALC, "(B-A)/(B+A)")
  field(EGU, "mm")
  field(PREC, "2")
}

record(calc, "SI:Ypos")
{
  field(INPA, "SI:BPMy0 CP MS")
  field(INPB, "SI:BPMy1 CP MS")
  field(CALC, "(B-A)/(B+A)")
  field(EGU, "mm")
  field(PREC, "2")
}

record(calc, "SI:Int")
{
  field(INPA, "SI:BPMx0 CP MS")
  field(INPB, "SI:BPMx1 CP MS")
  field(INPC, "SI:BPMy0 CP MS")
  field(INPD, "SI:BPMy1 CP MS")
  field(CALC, "(A+B+C+D)/4")
  field(EGU, "a.u.")
  field(PREC, "2")
}

### control for PID loop

record(ao, "SI:Hsetpoint")
{
    field(DESC, "Horizontal Position Setpoint")
    field(EGU, "mm")
    field(HOPR, "1")
    field(LOPR, "-1")
    field(DRVL, "-1")
    field(DRVH, "1")
    field(HIHI, "0.9")
    field(HIGH, "0.8")
    field(LOW , "-0.8")
    field(LOLO, "-0.9")
    field(PREC, "2")
    field(DOL,  "0")
    field(PINI, "YES")
}
record(ao, "SI:Vsetpoint")
{
    field(DESC, "Vertical Position Setpoint")
    field(EGU, "mm")
    field(HOPR, "1")
    field(LOPR, "-1")
    field(DRVL, "-1")
    field(DRVH, "1")
    field(HIHI, "0.9")
    field(HIGH, "0.8")
    field(LOW , "-0.8")
    field(LOLO, "-0.9")
    field(PREC, "2")
    field(DOL,  "0")
    field(PINI, "YES")
}

# Position error
# A - current position
# B - setpoint
record(calc, "SI:Herror")
{
    field(DESC, "Horizontal Position Error")
    field(SCAN, ".5 second")
    field(INPA, "SI:Xpos")
    field(INPB, "SI:Hsetpoint MS")
    field(CALC, "A-B")
    field(PREC, "2")
    field(FLNK, "SI:Hintegral")
}
record(calc, "SI:Verror")
{
    field(DESC, "Vertical Position Error")
    field(SCAN, ".5 second")
    field(INPA, "SI:Ypos")
    field(INPB, "SI:Vsetpoint MS")
    field(CALC, "A-B")
    field(PREC, "2")
    field(FLNK, "SI:Vintegral")
}

# Integrate error (A) but assert that
# it stays within limits (C)
record(calc, "SI:Hintegral")
{
    field(DESC, "Integrate Error for PID")
    field(PREC, "3")
    field(INPA, "SI:Herror PP MS")
    field(INPB, "SI:Hintegral")
    field(INPC, "20.0")
    field(CALC, "(B+A>C)?C:(B+A<-C)?(-C):(B+A)")
    field(FLNK, "SI:HPID")
}
record(calc, "SI:Vintegral")
{
    field(DESC, "Integrate Error for PID")
    field(PREC, "3")
    field(INPA, "SI:Verror PP MS")
    field(INPB, "SI:Vintegral")
    field(INPC, "20.0")
    field(CALC, "(B+A>C)?C:(B+A<-C)?(-C):(B+A)")
    field(FLNK, "SI:VPID")
}

# Every second, calculate new heater voltage via PID (PI)
# A - Kp
# B - error
# C - Ki
# D - error integral
record(calc, "SI:HPID")
{
    field(DESC, "H PID")
    field(PREC, "3")
    field(LOPR, "-1000")
    field(HOPR, "1000")
    field(HIHI, "900")
    field(HIGH, "500")
    field(LOW , "-500")
    field(LOLO, "-900")
    field(INPA, "10.0")
    field(INPB, "SI:Herror MS")
    field(INPC, "5.0")
    field(INPD, "SI:Hintegral MS")
    field(CALC, "A*B+C*D")
}
record(calc, "SI:VPID")
{
    field(DESC, "V PID")
    field(PREC, "3")
    field(LOPR, "-1000")
    field(HOPR, "1000")
    field(HIHI, "900")
    field(HIGH, "500")
    field(LOW , "-500")
    field(LOLO, "-900")
    field(INPA, "10.0")
    field(INPB, "SI:Verror MS")
    field(INPC, "5.0")
    field(INPD, "SI:Vintegral MS")
    field(CALC, "A*B+C*D")
}

# patch corr to work with PID loop
record(ao, "SI:Hcorr")
{
  field(DOL, "SI:HPID MS")
  field(OMSL,"closed_loop")
}
record(ao, "SI:Vcorr")
{
  field(DOL, "SI:VPID MS")
  field(OMSL,"closed_loop")
}
