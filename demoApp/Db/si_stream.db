# Database for simpleInstrument.py

record(waveform, "SI:ID")
{
  field(SCAN, "1 second")
  field(FTVL, "CHAR") # field type of value
  field(NELM, "100")
  field(DTYP, "stream")
  field(INP,  "@si.proto getID SI")
}

record(bo, "SI:Control")
{
  field(SCAN, "1 second")
  field(DTYP, "stream")
  field(OUT, "@si.proto setOn SI")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

record(bi, "SI:Status")
{
  field(SCAN, ".5 second")
  field(DTYP, "stream")
  field(INP, "@si.proto getOn SI")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

record(ao, "SI:Hcorr")
{
  field(DESC, "H Corrector Current")
  field(DTYP, "stream")
  field(OUT, "@si.proto setHcorr SI")
  field(EGU, "A")
  field(PREC, "3")
  field(DRVL, "-10")
  field(DRVH, "10")
  field(PINI, "YES")
  #field(DOL, "0")
  field(IVOA, "Set output to IVOV")
  field(IVOV, "0")
}
record(ao, "SI:Vcorr")
{
  field(DESC, "H Corrector Current")
  field(DTYP, "stream")
  field(OUT, "@si.proto setVcorr SI")
  field(EGU, "A")
  field(PREC, "3")
  field(DRVL, "-10")
  field(DRVH, "10")
  field(PINI, "YES")
  #field(DOL, "0")
  field(IVOA, "Set output to IVOV")
  field(IVOV, "0")
}

record(ai, "SI:BPMx0")
{
  field(SCAN, ".1 second")
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmx0 SI")
  field(PREC, "2")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMx1")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmx1 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMy0")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmy0 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(ai, "SI:BPMy1")
{
  field(DTYP, "stream")
  field(INP,  "@si.proto bpmy1 SI")
  field(PREC, "2")
  field(SCAN, "I/O Intr")
  field(EGU, "a.u.")
}

record(calc, "SI:Xpos")
{
  field(INPA, "SI:BPMx0 CP MS")
  field(INPB, "SI:BPMx1 CP MS")
  field(CALC, "(B-A)/(B+A)")
  field(EGU, "mm")
  field(PREC, "2")
}

record(calc, "SI:Ypos")
{
  field(INPA, "SI:BPMy0 CP MS")
  field(INPB, "SI:BPMy1 CP MS")
  field(CALC, "(B-A)/(B+A)")
  field(EGU, "mm")
  field(PREC, "2")
}

record(calc, "SI:Int")
{
  field(INPA, "SI:BPMx0 CP MS")
  field(INPB, "SI:BPMx1 CP MS")
  field(INPC, "SI:BPMy0 CP MS")
  field(INPD, "SI:BPMy1 CP MS")
  field(CALC, "(A+B+C+D)/4")
  field(EGU, "a.u.")
  field(PREC, "2")
}


